{{ define "discord.default.message" -}}
{
  "content": "{{ if eq .Status "firing" }}🔴 ALERTA CRÍTICO{{ else }}🟢 ALERTA RESOLVIDO{{ end }}",
  "embeds": [
    {
      "title": "{{ .GroupLabels.alertname }}",
      "color": {{ if eq .Status "firing" }}16711680{{ else }}65280{{ end }},
      "fields": [
        {
          "name": "Severidade",
          "value": "{{ .GroupLabels.severity }}",
          "inline": true
        },
        {
          "name": "Cluster",
          "value": "{{ .GroupLabels.cluster }}",
          "inline": true
        },
        {
          "name": "Status",
          "value": "{{ .Status | toUpper }}",
          "inline": false
        },
        {
          "name": "Resumo",
          "value": "{{ (index .Alerts 0).Annotations.summary }}",
          "inline": false
        },
        {
          "name": "Descrição",
          "value": "{{ (index .Alerts 0).Annotations.description }}",
          "inline": false
        }
      ]
    }
  ]
}
