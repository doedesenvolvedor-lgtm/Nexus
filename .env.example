# .env.example - Configuração do Nexus Streaming

# ===== Banco de Dados =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus

# ===== MercadoPago =====
MERCADOPAGO_ACCESS_TOKEN=your_access_token_here
MERCADOPAGO_CLIENT_ID=your_client_id_here
WEBHOOK_URL=http://localhost:8000

# ===== Autenticação =====
SECRET_KEY=your-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Email (Hostinger) =====
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@nexustwos.com
SMTP_PASSWORD=your-hostinger-email-password
SMTP_SECURITY=ssl
SMTP_FROM_EMAIL=noreply@nexustwos.com
SMTP_FROM_NAME=Nexus Streaming
SMTP_RETRY_ATTEMPTS=3
SMTP_RETRY_DELAY=5
# Alternativa STARTTLS (Hostinger):
# SMTP_PORT=587
# SMTP_SECURITY=starttls

# ===== Redis (Cache/Sessions) =====
REDIS_URL=redis://localhost:6379

# ===== API Base URLs =====
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
APP_NAME=Nexus Streaming

# ===== Admin Emails =====
ADMIN_EMAILS=admin@nexus.com,seu-email@nexus.com
