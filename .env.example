# .env.example - Configuração do Nexus Twos

# ===== Banco de Dados =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus

# ===== MercadoPago =====
MERCADOPAGO_ACCESS_TOKEN=your_access_token_here
MERCADOPAGO_CLIENT_ID=your_client_id_here
WEBHOOK_URL=http://localhost:8000
# Em produção (VPS): https://api.nexustwos.com

# ===== Autenticação =====
SECRET_KEY=your-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Email (Hostinger) =====
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@nexustwos.com
SMTP_PASSWORD=your-hostinger-email-password
SMTP_SECURITY=ssl
SMTP_FROM_EMAIL=noreply@nexustwos.com
SMTP_FROM_NAME=Nexus Twos
SMTP_RETRY_ATTEMPTS=3
SMTP_RETRY_DELAY=5
# Alternativa STARTTLS (Hostinger):
# SMTP_PORT=587
# SMTP_SECURITY=starttls

# ===== Redis (Cache/Sessions) =====
REDIS_URL=redis://localhost:6379

# ===== API Base URLs =====
API_URL=http://localhost:8000
# Em produção (VPS): https://api.nexustwos.com
FRONTEND_URL=http://localhost:3000
# Em produção (VPS): https://www.nexustwos.com
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
# Em produção (VPS): https://www.nexustwos.com/reset-password
APP_NAME=Nexus Twos

# ===== Admin Emails =====
ADMIN_EMAILS=admin@nexustwos.com,seu-email@nexustwos.com

# ===== Domínios VPS =====
# - Principal: https://www.nexustwos.com
# - API: https://api.nexustwos.com
# - Admin: https://admin.nexustwos.com
# - Política de Privacidade: https://privacypolicy.nexustwos.com
# - Termos de Uso: https://termosdeuso.nexustwos.com
