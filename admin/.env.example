# API Configuration
REACT_APP_API_URL=https://api.nexustwos.com
REACT_APP_API_TIMEOUT=30000

# Auth Configuration
REACT_APP_TOKEN_KEY=admin_token
REACT_APP_EMAIL_KEY=admin_email
REACT_APP_TOKEN_EXPIRY=86400000

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_DEBUG_MODE=false
REACT_APP_CRASH_REPORTING=true

# Security
REACT_APP_ENABLE_CSRF=true
REACT_APP_ENABLE_CSP=true

# Version
REACT_APP_VERSION=1.0.0

# Environment
NODE_ENV=production
