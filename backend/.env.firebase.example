# Firebase Configuration
# Caminho para o arquivo JSON de credenciais do Firebase
# Baixe em: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# Firebase Project ID
FIREBASE_PROJECT_ID=nexus-3fb82

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=nexus-3fb82.firebasestorage.app
